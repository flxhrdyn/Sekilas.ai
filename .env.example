GROQ_API_KEY=your_groq_api_key
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_OUTPUT_DIM=384
CLASSIFIER_MODEL=qwen/qwen3-32b
SUMMARIZER_MODEL=qwen/qwen3-32b
QA_MODEL=qwen/qwen3-32b

# Qdrant Cloud
QDRANT_URL=https://your-cluster-id.region.aws.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION=sekilas_ai

# Runtime
REQUEST_TIMEOUT_SECONDS=20
USER_AGENT=sekilas-ai-agentic-rag/0.1 (+https://github.com)
DEDUP_THRESHOLD=0.92
MIN_CONTENT_CHARS=200
SUMMARY_MAX_CONTENT_CHARS=2000

# Notifier
ENABLE_TELEGRAM_NOTIFY=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
DASHBOARD_URL=

# Catatan:
# File ini adalah template untuk disalin menjadi .env.
# Aplikasi membaca .env secara otomatis.
